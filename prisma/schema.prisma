generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  phone              String   @unique
  password           String
  email              String?
  role               String   @default("CLIENT") // CLIENT, PRESTATAIRE, ENTREPRISE, ADMIN
  status             String   @default("approved") // pending, approved, rejected, suspended
  autoReplyMessage   String? 
  deletionReason     String? 
  deletionRequestedAt DateTime?
  certified          Boolean  @default(false)
  certificationStatus String? // "pending" | "rejected" | null (null = none/approved)
  certificationMessage String?
  certificationRequestedAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clientProfile      ClientProfile?
  providerProfile    ProviderProfile?
  companyProfile     CompanyProfile?
  reviewsWritten     Review[]
  reviewsReceived    Review[]  @relation("ReviewedUser")
  notifications      Notification[]
  contactMessages    ContactMessage[]
  announcementsSent  AdminAnnouncement[] @relation("AnnouncementAuthor")
  conversations1     Conversation[] @relation("ConvParticipant1")
  conversations2     Conversation[] @relation("ConvParticipant2")
  chatMessages       ChatMessage[]
}

model ClientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String?
  email     String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  fullName      String
  email         String
  phone         String
  photoUrl      String?
  sector        String
  service       String
  services      String?  // JSON array
  province      String?
  commune       String?
  description   String?
  socialMedia   String?  // JSON string
  nationalScope Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String
  email         String
  phone         String
  logoUrl       String?
  coverPhotoUrl String?
  sector        String
  companyType   String   @default("individuelle")
  employeeCount Int?
  website       String?
  fullAddress   String?
  description   String?
  services      String?
  province      String?
  commune       String?
  socialMedia   String?
  nationalScope Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id          String   @id @default(cuid())
  authorId    String
  targetId    String
  targetType  String
  rating      Int
  comment     String?
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  target      User     @relation("ReviewedUser", fields: [targetId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  reply     String?
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AdminAnnouncement {
  id          String   @id @default(cuid())
  authorId    String
  title       String
  message     String
  targetType  String
  targetId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String   @id @default(cuid())
  participant1Id  String
  participant2Id  String
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  participant1    User     @relation("ConvParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2    User     @relation("ConvParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)

  messages        ChatMessage[]

  @@unique([participant1Id, participant2Id])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())
}